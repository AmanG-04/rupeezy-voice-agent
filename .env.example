# ==============================================================
# Rupeezy AI Voice Agent — environment variables
# Copy this file to `.env` (project root) AND `backend/.env`
# Never commit your real .env file. See .gitignore.
# ==============================================================

# --- Gemini (Google AI Studio) ---
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Models — pin versions so prod is reproducible
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_REASONING_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- LiveKit Cloud (free tier) ---
# Sign up at https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Supabase (free tier) ---
# Project URL + anon key for frontend, service-role key for backend ONLY
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO
# Comma-separated origins for CORS (frontend dev URL)
BACKEND_CORS_ORIGINS=http://localhost:5173

# --- Frontend (Vite) ---
# Vite only exposes vars prefixed with VITE_ to the browser bundle.
# These belong in frontend/.env (NOT this file in production).
VITE_API_BASE_URL=http://localhost:8000
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- Local DB (Phases 1–3 use SQLite, Phase 4 switches to Supabase) ---
DATABASE_URL=sqlite:///./backend/data/rupeezy.db

# --- WhatsApp (mocked in Phase 8; real Cloud API later) ---
WHATSAPP_MODE=mock
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
