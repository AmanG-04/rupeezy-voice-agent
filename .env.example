# ==============================================================
# Rupeezy AI Voice Agent — environment
# Copy this file to `.env` (project root). Never commit your real .env.
# ==============================================================

# --- REQUIRED ---
# Free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here


# --- OPTIONAL (sensible defaults; override only if you need to) ---

# Gemini model chain. Primary tried first, then GEMINI_CHAT_MODEL_FALLBACKS
# (comma-separated) in order on 429. Each model has its own free-tier quota
# pool so the demo doesn't go dark mid-call when one exhausts.
# GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_CHAT_MODEL_FALLBACKS=gemini-3-flash-preview,gemini-2.5-flash-lite
# GEMINI_REASONING_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# Database. Default is SQLite at backend/data/rupeezy.db (perfect for local
# dev, but ephemeral on Render free tier — wipes on every redeploy).
# Set this to a Postgres URL (Supabase / Neon / etc.) to persist data across
# redeploys. The engine accepts SQLAlchemy-style URLs and the legacy
# `postgres://...` form Supabase shows in its UI (auto-rewritten). See
# SUPABASE_SETUP.md for the 5-minute setup.
# DATABASE_URL=sqlite:///./backend/data/rupeezy.db
# DATABASE_URL=postgresql+psycopg://user:pass@host:6543/postgres

# Comma-separated origins allowed by FastAPI CORS. Add your prod frontend
# URL here when deploying (e.g. https://rupeezy-agent.vercel.app).
# BACKEND_CORS_ORIGINS=http://localhost:5173

# Backend log level — DEBUG / INFO / WARNING / ERROR.
# BACKEND_LOG_LEVEL=INFO

# Backend bind host/port. On Render the port comes from $PORT — don't set
# this there. Local dev uses these defaults.
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000

# WhatsApp dispatch mode. "mock" (default) renders the Appendix §9 templates
# and persists a whatsapp_log row with status='sent_mock'. The real Cloud
# API wiring is stubbed but not invoked — keep this as "mock" for the demo.
# WHATSAPP_MODE=mock
